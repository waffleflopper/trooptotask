{
	"rewrites": [
		{
			"source": "/:path*",
			"has": [{ "type": "host", "value": "admin.trooptotask.org" }],
			"destination": "/admin/:path*"
		}
	],
	"crons": [
		{
			"path": "/api/cleanup-demo-sandboxes",
			"schedule": "0 3 * * *"
		},
		{
			"path": "/api/cleanup-old-data",
			"schedule": "0 4 * * 0"
		},
		{
			"path": "/api/cleanup-archived-personnel",
			"schedule": "0 5 * * *"
		},
		{
			"path": "/api/cleanup-expired-onboardings",
			"schedule": "0 6 * * *"
		}
	]
}
